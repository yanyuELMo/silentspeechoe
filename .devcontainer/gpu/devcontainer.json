{
  "name": "silentspeechoe-dev-gpu",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../docker-compose.gpu.yml"
  ],
  "service": "dev",
  "workspaceFolder": "/workspace/silentspeechoe",
  "shutdownAction": "stopCompose",
  "postCreateCommand": "python3 -m pip install --upgrade pip && python3 -m pip install -r .devcontainer/requirements-dev.txt -e .",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ],
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "ms-vscode-remote.remote-containers",
        "redhat.vscode-yaml"
      ]
    }
  }
}
